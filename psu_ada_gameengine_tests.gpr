-- psu_ada_gameengine_tests.gpr
-- Test project for building test executables

with "psu_ada_gameengine.gpr";

project Psu_Ada_Gameengine_Tests is

   for Languages use ("Ada");
   
   -- Source directories include tests
   for Source_Dirs use ("tests");
   
   -- Build artifacts
   for Object_Dir use "obj/tests";
   for Exec_Dir use "bin";
   for Create_Missing_Dirs use "True";
   
   -- Define the test executables
   for Main use ("component_table_test.adb", 
                 "ecs_store_test.adb", 
                 "ecs_integration_test.adb");
   
   package Compiler is
      for Default_Switches ("Ada") use ("-Og", "-gnat2022", "-gnatX0");
   end Compiler;
   
   package Binder is
      for Switches ("Ada") use ("-Es"); -- Symbolic traceback
   end Binder;

end Psu_Ada_Gameengine_Tests;
